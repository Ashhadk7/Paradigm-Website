# Paradigm SPA — Apache config for SiteGround (and any cPanel/Apache host)

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files/directories as-is (assets, images, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else falls back to index.html so client-side routing works
  # on deep links and page refreshes (/process, /about, /contact, ...).
  RewriteRule ^ index.html [L]
</IfModule>

# Long-cache fingerprinted build assets; never cache index.html
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|svg|png|jpe?g|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Gzip text assets for faster loads
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

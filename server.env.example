# Configure these as server-only Vercel Environment Variables.
# Never prefix server secrets with VITE_.
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key

OPENAI_API_KEY=your_server_only_openai_api_key
OPENAI_CODE_MODEL=gpt-5.4

GITHUB_OWNER=Ashhadk7
GITHUB_REPO=Paradigm-Website
GITHUB_BASE_BRANCH=main
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_INSTALLATION_ID=your_github_app_installation_id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"


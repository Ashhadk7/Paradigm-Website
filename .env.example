VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Code Change agent: shows the "Code Change" tab in the admin assistant.
# Set to anything other than "false" (or remove this line) to ENABLE it.
# The agent ALSO needs the server secrets in server.env.example configured in
# Vercel (OPENAI_API_KEY, SUPABASE_SERVICE_ROLE_KEY, GitHub App keys) — without
# them the tab shows but generation will fail. See docs/code-change-agent.md.
VITE_ENABLE_CODE_AGENT=false

# This file is only for values safe to expose to the Vite browser app.
# Do not place OpenAI, service-role, GitHub App, or deployment secrets here.

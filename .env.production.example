# Production env for a SiteGround (static) build.
# Copy this to `.env.production`, fill in REAL values, then run `npm run build`.
# Vite bakes these into dist/ at build time — there is no server env on SiteGround.
#
#   cp .env.production.example .env.production
#   # edit .env.production with the real values
#   npm run build
#   # upload everything inside dist/ (including .htaccess) to public_html

# Supabase — powers the /admin CMS and live page content.
# Without these, public pages still work (they fall back to default copy),
# but the /admin dashboard and live content editing will not function.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Klaviyo — Book a 20-Minute Call popup. Without these the form opens but
# submissions will not be sent.
VITE_KLAVIYO_PUBLIC_KEY=
VITE_KLAVIYO_LIST_ID=

# Code agent is a dev/admin tool — keep disabled in production.
VITE_ENABLE_CODE_AGENT=false
